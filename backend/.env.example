PORT=3000
NODE_ENV=development

# local = JSON file in backend/data/ (dev only)
# mysql = Hostinger MySQL (production on Render)
DB_TYPE=local

DB_HOST=mysql123.hostinger.com
DB_PORT=3306
DB_USER=u123456789_sirivruddhi
DB_PASSWORD=your_password
DB_DATABASE=u123456789_sirivruddhi

# Set true for Hostinger remote MySQL from Render
DB_SSL=true

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:4200,https://sirivruddhi.com,https://www.sirivruddhi.com,https://admin.sirivruddhi.com

# Admin module (Phase 1) — set both before enabling /admin login
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_JWT_SECRET=change_me_to_a_long_random_string
ADMIN_EMAIL=sirivruddhi@gmail.com

# Email notifications — Resend (production on Render; SMTP blocked there)
NOTIFY_EMAIL=sirivruddhi@gmail.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Siri Vruddhi <onboarding@resend.dev>

# Gmail SMTP — local dev only (does not work on Render)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=sirivruddhi@gmail.com
# SMTP_PASS=your_gmail_app_password
